# Backend API Key (optional — leave blank to disable auth)
# When set, every request must include:  X-Client-Key: <value>
API_KEY=

# Required API Keys
# Get free keys at: https://console.groq.com  &  https://console.mistral.ai
GROQ_API_KEY=your_groq_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here

# Mistral Agent (optional — used by mistral-agent endpoint)
MISTRAL_AGENT_ID=your_mistral_agent_id_here

# Service URLs
BACKEND_URL=http://localhost:8000
