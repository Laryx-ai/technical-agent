# Backend API Key (optional — leave blank to disable auth)
# When set, every request must include:  X-Client-Key: <value>
API_KEY=

# LLM API Keys 
GROQ_API_KEY=your_groq_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
HF_TOKEN=your_huggingface_token_here

# Mistral Agent (optional — used by the /chat mistral-agent endpoint)
MISTRAL_AGENT_ID=your_mistral_agent_id_here

# Service URLs
# For local development the frontend calls the backend at localhost.
# When running with docker-compose this is overridden to http://backend:8000
BACKEND_URL=http://localhost:8000
